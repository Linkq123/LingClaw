{
  "name": "lingclaw-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "fmt:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "dompurify": "^3.1.6",
    "highlight.js": "^11.9.0",
    "katex": "^0.16.9",
    "marked": "^12.0.0",
    "marked-highlight": "^2.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
